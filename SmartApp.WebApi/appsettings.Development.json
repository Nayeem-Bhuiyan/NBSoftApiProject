  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Debug",
      "Microsoft.EntityFrameworkCore": "Debug",
      "System": "Information",
      "SmartApp": "Debug"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "HH:mm:ss ",
        "UseUtcTimestamp": false
      }
    }
  },
  "FileImageSettings": {
    "BaseFolderPath_For_Images": "/app/wwwroot/UploadedImages",
    "BaseFolderPath_For_Files": "/app/wwwroot/UploadedFiles",
    "MaxImageFileSizeInMB": 10,
    "MaxDocumentFileSizeInMB": 20,
    "AllowedImageMimeTypes": [
      "image/jpeg",
      "image/png",
      "image/webp",
      "image/gif",
      "image/svg+xml"
    ],
    "AllowedDocumentMimeTypes": [
      "application/pdf",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.ms-excel",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "fcgvdsftryhty6756y7mu8iu56ygfcbvtgfdr6t34t5hji67845tgfdgty345yru756!",
    "Issuer": "SmartAppAPI",
    "Audience": "SmartAppClient",
    "AccessTokenExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 30,
    "RefreshTokenRotationGraceSeconds": 60,
    "AllowInsecureHttp": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:5232",
      "http://127.0.0.1:5232",
      "http://localhost:8080",
      "http://localhost:3000",
      "http://localhost:5000",
      "http://host.docker.internal:4200",
      "http://host.docker.internal:8080"
    ]
  },
  "ApiDocumentation": {
    "EnableOpenApi": true,
    "EnableScalar": true
  },
  "RateLimit": {
    "Enabled": false,
    "Policies": {
      "General": {
        "PermitLimit": 1000,
        "WindowSeconds": 60,
        "KeyType": "IP"
      },
      "Login": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "KeyType": "IP"
      },
      "PasswordReset": {
        "PermitLimit": 5,
        "WindowSeconds": 3600,
        "KeyType": "User"
      },
      "Admin": {
        "PermitLimit": 100,
        "WindowSeconds": 60,
        "KeyType": "User"
      },
      "Refresh": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "KeyType": "IP"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Debug",
        "Microsoft.AspNetCore": "Debug",
        "System": "Information",
        "Microsoft.Hosting": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/smartapp-dev-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "buffered": false,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithThreadId",
      "WithProcessId",
      "WithCorrelationId"
    ],
    "Properties": {
      "Application": "SmartApp.WebApi",
      "Environment": "Development"
    }
  },
  "LogSettings": {
    "EnableRequestLogging": true,
    "EnableResponseLogging": true,
    "LogFilePath": "/app/logs/smartapp-dev-.log",
    "RetainedFileCount": 7,
    "MsSqlTableName": "ApplicationLogs",
    "SensitiveFields": [
      "password",
      "newpassword",
      "confirmpassword",
      "refreshtoken",
      "accesstoken",
      "token",
      "secret",
      "apikey",
      "cardnumber",
      "cvv",
      "pin",
      "authorization",
      "cookie"
    ],
    "ExcludedPaths": [
      "/health",
      "/metrics",
      "/scalar",
      "/openapi",
      "/swagger"
    ]
  },
  "SeedData": {
    "EnableSeeding": true,
    "ExpectedRecordCount": 1000,
    "BatchSize": 100,
    "UseBulkCopy": false,
    "MaxParallelBatches": 1,
    "TimeoutSeconds": 300,
    "EnableProgressLogging": true
  },
  "Development": {
    "EnableDetailedErrors": true,
    "EnableSensitiveDataLogging": true,
    "EnableDatabaseErrorLogging": true,
    "ShowStackTraceInResponse": true
  },
  "Database": {
    "EnableRetryOnFailure": true,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 30,
    "CommandTimeout": 120
  },
  "Redis": {
    "InstanceName": "SmartApp_Dev",
    "DefaultDatabase": 0,
    "EnableKeyspaceNotifications": true
  }
}